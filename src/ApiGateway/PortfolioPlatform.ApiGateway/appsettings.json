{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "blog-route": {
        "ClusterId": "blog-cluster",
        "Match": {
          "Path": "/api/blog/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "cv-route": {
        "ClusterId": "cv-cluster",
        "Match": {
          "Path": "/api/cv/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "portfolio-route": {
        "ClusterId": "portfolio-cluster",
        "Match": {
          "Path": "/api/portfolio/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "file-route": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        }
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "blog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5273/"
          }
        }
      },
      "cv-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5274/"
          }
        }
      },
      "portfolio-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5275/"
          }
        }
      },
      "file-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5272/"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5156/"
          }
        }
      }
    }
  }
}